<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="900.0" styleClass="root-container" stylesheets="@../css/Compra.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Region layoutX="800.0" layoutY="40.0" prefHeight="150.0" prefWidth="150.0" styleClass="purple-bubble-solid" />
        <Region layoutX="-30.0" layoutY="550.0" prefHeight="220.0" prefWidth="220.0" styleClass="purple-bubble-outline" />

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" stylesheets="@../css/Compra.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="30.0" stylesheets="@../css/Compra.css">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>

                        <VBox spacing="5.0">
                            <children>
                                <Label stylesheets="@../css/Compra.css" text="PROCESO DE COMPRA" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                                <Label text="Personaliza las entradas y finaliza la compra" textFill="#e9d5ff" />
                            </children>
                        </VBox>

                        <HBox spacing="30.0">
                            <children>

                                <VBox spacing="25.0" stylesheets="@../css/Compra.css" HBox.hgrow="ALWAYS">
                                    <children>

                                        <VBox styleClass="content-card">
                                            <padding>
                                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="1. Entradas Seleccionadas" />
                                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                                                    <children>
                                                        <VBox HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="entradas seleccionadas" />
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #c084fc;" text="Precio unitario: 0" />
                                                            </children>
                                                        </VBox>
                                                        <Label text="Cantidad:" />
                                                        <Spinner prefWidth="100.0" styleClass="custom-spinner" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox styleClass="content-card">
                                            <padding>
                                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="2. Servicios Adicionales" />
                                                <VBox spacing="15.0" style="-fx-padding: 15 0 0 0;">
                                                    <children>
                                                        <CheckBox mnemonicParsing="false" text="Acesso VIP(0)" />
                                                        <CheckBox mnemonicParsing="false" stylesheets="@../css/Compra.css" text="Seguro de cancelación(0)" />
                                                        <CheckBox mnemonicParsing="false" text="merchandising (0)" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>

                                <VBox prefWidth="360.0" spacing="25.0">
                                    <children>

                                        <VBox spacing="20.0" styleClass="glass-info-card">
                                            <padding>
                                                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e9d5ff;" text="RESUMEN DE COMPRA" />

                                                <VBox spacing="12.0" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                                                    <children>
                                                        <HBox>
                                                            <children>
                                                                <Label text="Subtotal Entradas" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label text="0" />
                                                            </children>
                                                        </HBox>
                                                        <HBox>
                                                            <children>
                                                                <Label text="Servicios Adicionales" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label text="0" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TOTAL:" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d946ef;" text="0" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="15.0">
                                            <children>
                                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="button-buy" stylesheets="@../css/Compra.css" text="CONFIRMAR Y PAGAR" />
                                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="button-back-light" stylesheets="@../css/DetalleEventos.css" text="Modificar Seleccion" />
                                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="button-cancel" text="Cancelar Compra" />
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>

                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
