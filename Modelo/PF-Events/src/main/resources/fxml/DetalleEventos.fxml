                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox prefHeight="494.0" prefWidth="327.0" spacing="20.0">
                                    <children>
                                        <VBox alignment="CENTER" style="-fx-border-color: #ccc; -fx-padding: 15;" stylesheets="@../css/DetalleEventos.css">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" styleClass="section-title" stylesheets="@../css/DetalleEventos.css" text="Mapa de Localidades" />
                                                <ImageView fitHeight="200.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" styleClass="banner-image" />
                                            </children>
                                 <styleClass>
                                    <String fx:value="banner-container" />
                                    <String fx:value="glass-info-card" />
                                 </styleClass>
                                        </VBox>

                                        <VBox style="-fx-border-color: #ccc; -fx-padding: 15;" styleClass="content-card" stylesheets="@../css/DetalleEvento.css">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Precios por Zona" />
