                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER">
                                                            <children>
                                                                <Label text="Preferencial" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label style="-fx-font-weight: bold;" text="0" />
                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER">
                                                            <children>
                                                                <Label text="General" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label style="-fx-font-weight: bold;" text="0" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" stylesheets="@../css/DetalleEventos.css" text="RESERVAR AHORA">
