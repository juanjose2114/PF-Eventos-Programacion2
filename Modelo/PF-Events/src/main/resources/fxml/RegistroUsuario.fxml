<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="700.0" prefWidth="780.0" styleClass="main-bg-gradient" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.poo.controller.RegistroController">
    <children>

        <Region layoutX="-40.0" layoutY="40.0" prefHeight="190.0" prefWidth="190.0" styleClass="purple-bubble-outline" />
        <Region layoutX="120.0" layoutY="-20.0" prefHeight="100.0" prefWidth="100.0" styleClass="purple-bubble-outline" />
        <Region layoutX="620.0" layoutY="80.0" prefHeight="170.0" prefWidth="170.0" styleClass="purple-bubble-outline" />
        <Region layoutX="30.0" layoutY="520.0" prefHeight="150.0" prefWidth="150.0" styleClass="purple-bubble-solid" />
        <Region layoutX="590.0" layoutY="440.0" prefHeight="240.0" prefWidth="240.0" styleClass="purple-bubble-solid" />
        <Region layoutX="500.0" layoutY="280.0" prefHeight="90.0" prefWidth="90.0" styleClass="purple-bubble-outline" />

        <StackPane styleClass="main-bg-gradient" stylesheets="@../css/RegistroUsuario.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox alignment="CENTER" maxWidth="460.0" spacing="12.0" stylesheets="@../css/RegistroUsuario.css">
                    <children>

                        <VBox alignment="CENTER" spacing="3.0" stylesheets="@../css/RegistroUsuario.css">
                            <children>
                                <Text fill="#2e1065" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="main-bg-gradient" text="Crear Cuenta">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Text>
                                <Text fill="#6b21a8" strokeType="OUTSIDE" strokeWidth="0.0" text="Ingresa tus datos personales">
                                    <font>
                                        <Font name="System Italic" size="13.0" />
                                    </font>
                                </Text>
                            </children>
                            <VBox.margin>
                                <Insets bottom="5.0" />
                            </VBox.margin>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Nombre Completo" textFill="#4c1d95" />
                                <TextField fx:id="txtNombre" promptText="nombre completo" styleClass="neon-input-field" />

                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Correo Electrónico" textFill="#4c1d95" />
                                <TextField fx:id="txtCorreo" promptText="correo electronico" styleClass="neon-input-field" />

                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Teléfono" textFill="#4c1d95" />
                                <TextField fx:id="txtTelefono" promptText="telefono" styleClass="neon-input-field" />

                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Contraseña" textFill="#4c1d95" />
                                <PasswordField fx:id="txtContrasenia" promptText="contraseña" styleClass="neon-input-field" />

                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Método de Pago" textFill="#4c1d95" />
                                <ComboBox fx:id="cmbMetodoPago" maxWidth="1.7976931348623157E308" promptText="Seleccionar método de pago..." styleClass="neon-combobox" stylesheets="@../css/RegistroUsuario.css" />
                            </children>
                        </VBox>

                        <Button fx:id="btnRegistrar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onRegistrarAction" styleClass="button-purple-gradient" stylesheets="@../css/RegistroUsuario.css" text="Completar Registro">
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Button>

                        <Button fx:id="btnAtras" mnemonicParsing="false" onAction="#onAtrasAction" styleClass="back-link-login" text="Volver al inicio de sesión" />

                    </children>
                    <padding>
                        <Insets bottom="25.0" left="35.0" right="35.0" top="25.0" />
                    </padding>
               <styleClass>
                  <String fx:value="glass-card" />
                  <String fx:value="purple-bubble-solid" />
               </styleClass>
                </VBox>

            </children>
        </StackPane>
    </children>
</AnchorPane>
