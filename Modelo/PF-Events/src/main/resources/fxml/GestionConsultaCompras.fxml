<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="900.0" styleClass="root-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox spacing="30.0" styleClass="root-container" stylesheets="@../css/GestionConsultaCompras.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
            </padding>
            <children>

                <VBox prefWidth="260.0" spacing="25.0" styleClass="content-card">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
                            <children>
                                <Region prefHeight="80.0" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 40; -fx-border-color: #d946ef; -fx-border-radius: 40; -fx-border-width: 2;" />
                                <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Nombre usuario" textFill="WHITE" />
                            </children>
                        </VBox>
                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="profile-menu-btn" text="Editar Datos Personales" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="profile-menu-btn" text="Gestionar Metodos de Pago" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="profile-menu-btn-active" text="Consultar Compras" />
                            </children>
                        </VBox>
                        <VBox spacing="12.0">
                            <children>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="button-back-light" text="Volver al Inicio" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="button-logout" text="Cerrar Sesion" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="25.0" HBox.hgrow="ALWAYS">
                    <children>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="HISTORIAL DE COMPRAS" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Revisa tus eventos adquiridos y descarga tus comprobantes en cualquier momento" textFill="#e9d5ff" />
                            </children>
                        </VBox>

                        <HBox spacing="15.0" styleClass="content-card">
                            <padding>
                                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                            </padding>
                            <children>
                                <TextField promptText="Buscar por nombre de evento o codigo..." stylesheets="@../css/GestionConsultaCompras.css" HBox.hgrow="ALWAYS">
                           <styleClass>
                              <String fx:value="custom-field" />
                              <String fx:value="text-input" />
                           </styleClass></TextField>
                                <ComboBox prefHeight="30.0" prefWidth="150.0" promptText="Estado" styleClass="button-back-light" stylesheets="@../css/GestionConsultaCompras.css" />
                            </children>
                        </HBox>

                        <VBox spacing="15.0" styleClass="glass-info-card" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 15px;" text=" nombre Evento" textFill="WHITE" />
                                                <Label style="-fx-font-size: 12px;" text="compra - Fecha" textFill="#94a3b8" />
                                            </children>
                                        </VBox>
                                        <Label style="-fx-font-weight: bold;" text="Total: 0" textFill="#d946ef" />
                                        <Button style="-fx-font-size: 11px; -fx-padding: 5 12;" styleClass="button-pdf" stylesheets="@../css/GestionConsultaCompras.css" text="Formato" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 15px;" text="nombre Evento" textFill="WHITE" />
                                                <Label style="-fx-font-size: 12px;" text="compra - Fecha " textFill="#94a3b8" />
                                            </children>
                                        </VBox>
                                        <Label style="-fx-font-weight: bold;" text="Total: 0" textFill="#d946ef" />
                                        <Button style="-fx-font-size: 11px; -fx-padding: 5 12;" styleClass="button-csv" stylesheets="@../css/GestionConsultaCompras.css" text="Formato" />
                                    </children>
                                </HBox>

                                <Region VBox.vgrow="ALWAYS" />

                                <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
                                    <children>
                                        <Label style="-fx-font-size: 13px;" text="Exportar todo el historial:" textFill="#cbd5e1" />
                                        <Button mnemonicParsing="false" styleClass="button-descargar" stylesheets="@../css/GestionConsultaCompras.css" text="Descargar CSV" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>
